{
  "version": 2,
  "builds": [
    {
      "src": "server.js",
      "use": "@vercel/node",
      "config": { "maxDuration": 60, "includeFiles": ["evercrafted-shop-data.json", "evercrafted-schema.js"] }
    },
    { "src": "*.html", "use": "@vercel/static" },
    { "src": "assets/**", "use": "@vercel/static" },
    { "src": "evercrafted-*.js", "use": "@vercel/static" },
    { "src": "engine.js", "use": "@vercel/static" }
  ],
  "routes": [
    { "src": "/api/(.*)", "dest": "server.js" },
    { "src": "/", "dest": "/evercrafted-marketing-site.html" },
    { "handle": "filesystem" }
  ]
}
