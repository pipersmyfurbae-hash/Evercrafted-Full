# ── Evercrafted API — environment variables ─────────────────────────────────
# Copy this file to .env and fill in real values:  cp .env.example .env

# Anthropic API key (server-side only — never expose to the browser)
ANTHROPIC_API_KEY=sk-ant-...

# Port for local dev (Vercel sets this automatically in production)
PORT=3001

# ── Supabase (waitlist storage) ─────────────────────────────────────────────
# Project: "Evercrafted"  →  https://qybnmlqesnbmgxayhllf.supabase.co
# Use the SERVICE ROLE key here (server-side only). It bypasses RLS so the
# server can insert waitlist rows. NEVER ship the service role key to the client.
# If these two are left blank, /api/waitlist falls back to writing waitlist.json.
SUPABASE_URL=https://qybnmlqesnbmgxayhllf.supabase.co
SUPABASE_SERVICE_ROLE_KEY=

# ── Image generation (render the wreath from its prompt) ────────────────────
# Choose ONE provider. Flux (fal.ai) is recommended — the render prompts are
# Flux-tuned, it's an official API, fast, with clean commercial terms.
# If IMAGE_PROVIDER is blank it auto-detects from whichever key is set.
# IMAGE_PROVIDER=fal            # or: openai | midjourney
# FAL_KEY=                      # from https://fal.ai/dashboard/keys
# OPENAI_API_KEY=              # from https://platform.openai.com (used if provider=openai)
#
# Midjourney (optional, "aesthetic" provider) via APIframe — an UNOFFICIAL MJ
# relay. Great look, but: no SLA, MJ-ToS gray area, slow (~30–60s async). Used
# only by /api/render, never for cutouts. Set IMAGE_PROVIDER=midjourney + the key.
# APIFRAME_API_KEY=             # from https://apiframe.pro (bundles the MJ account)
# APIFRAME_MODE=fast            # relax | fast | turbo  (turbo is fastest/costliest)
#
# fal model tiers (closest-to-Midjourney → cheapest). Optional overrides:
#   FAL_MODEL        renders   (default fal-ai/flux-pro/v1.1; try ...v1.1-ultra for max quality)
#   FAL_ASSET_MODEL  cutouts   (default fal-ai/flux/dev — cheap, fine for single sprigs)
# FAL_MODEL=fal-ai/flux-pro/v1.1
# FAL_ASSET_MODEL=fal-ai/flux/dev
# FAL_BG_MODEL=fal-ai/birefnet      # ML background removal for clean cutouts

# ── BRC realism pass (Blueprint-to-Render Compositor, Editorial mode) ───────
# Replicate token for the Flux Kontext realism pass (server-side only). From
# https://replicate.com/account/api-tokens — looks like r8_... .  Until it's set,
# /api/realism returns 503 and BRC's Proof mode still works (exact composite, no AI).
REPLICATE_API_TOKEN=

# ── Stripe billing (marketplace packs) ──────────────────────────────────────
# Until STRIPE_SECRET_KEY is set, /api/checkout + /api/stripe/webhook return 503.
# See docs/auth-billing-setup.md for the full go-live steps.
# STRIPE_SECRET_KEY=sk_live_or_test_...
# STRIPE_WEBHOOK_SECRET=whsec_...        # from the Stripe webhook endpoint
# STRIPE_PRICE_OPS=price_...             # monthly Price IDs, one per pack
# STRIPE_PRICE_SELL=price_...
# STRIPE_PRICE_GROW=price_...
# STRIPE_PRICE_PRO=price_...
# PUBLIC_URL=https://evercrafted.com     # fallback origin for checkout success/cancel

# ── Plan limits ─────────────────────────────────────────────────────────────
# Monthly caps on paid AI actions apply to SUBSCRIBERS by tier (edit TIER_LIMITS
# in server.js). Owners listed here are NEVER limited. Your tools run as owner
# 'default', so you (admin) are already unlimited — add more owners if needed.
ADMIN_OWNERS=default

# ── CORS ────────────────────────────────────────────────────────────────────
# Comma-separated list of extra browser origins allowed to call the API.
# localhost origins and file:// are always allowed. Add your production domain:
# ALLOWED_ORIGINS=https://evercrafted.com,https://www.evercrafted.com
ALLOWED_ORIGINS=
